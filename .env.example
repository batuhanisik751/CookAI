# Database
DATABASE_URL=postgresql+asyncpg://cookai:cookai@localhost:5432/cookai
DATABASE_URL_SYNC=postgresql://cookai:cookai@localhost:5432/cookai

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Whisper (OpenAI API — or leave empty for local model)
OPENAI_API_KEY=your-openai-api-key

# App Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Video Processing
MAX_VIDEO_DURATION_SECONDS=300
TEMP_MEDIA_DIR=./tmp/media
